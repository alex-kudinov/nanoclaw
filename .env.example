
# ── Claude Auth ──────────────────────────────────────────────────────────────
# Use one: OAuth token (from `claude /login`) or API key
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=

# Key pool (optional — round-robin across up to 5 keys)
# CLAUDE_CODE_OAUTH_TOKEN_1=
# CLAUDE_CODE_OAUTH_TOKEN_2=
# ANTHROPIC_API_KEY_1=
# ANTHROPIC_API_KEY_2=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ONLY=true

# ── Assistant Identity ────────────────────────────────────────────────────────
ASSISTANT_NAME=Andy

# ── Webhook Server ────────────────────────────────────────────────────────────
WEBHOOK_PORT=8088
WEBHOOK_SECRET=change-me

# ── Container Runtime ─────────────────────────────────────────────────────────
# Apple Container: 192.168.64.1 (default)
# Docker Desktop:  host.docker.internal
CONTAINER_HOST_IP=192.168.64.1
CONTAINER_IMAGE=nanoclaw-agent:latest
CONTAINER_TIMEOUT=1800000
IDLE_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5

# ── Token Proxy ───────────────────────────────────────────────────────────────
PROXY_PORT=40960

# ── Infrastructure Reference (not used by code — preserved for ops) ──────────
# MAC_MINI_HOST=
# MAC_MINI_USER=
# MAC_MINI_SSH_KEY=
# VPS_HOST=
# VPS_PORT=
# VPS_USER=
# VPS_SSH_KEY=
# N8N_URL=
