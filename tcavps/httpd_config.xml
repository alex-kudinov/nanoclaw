<?xml version="1.0" encoding="UTF-8"?>
<httpServerConfig>
  <serverName>$HOSTNAME</serverName>
  <workerProcesses>2</workerProcesses>
  <user>tca</user>
  <group>tca</group>
  <priority>0</priority>
  <chrootPath>/</chrootPath>
  <enableChroot>0</enableChroot>
  <enableLVE>0</enableLVE>
  <inMemBufSize>512M</inMemBufSize>
  <swappingDir>/tmp/lshttpd/swap</swappingDir>
  <autoFix503>1</autoFix503>
  <enableh2c>1</enableh2c>
  <loadApacheConf>0</loadApacheConf>
  <mime>$SERVER_ROOT/conf/mime.properties</mime>
  <disableInitLogRotation>1</disableInitLogRotation>
  <showVersionNumber>0</showVersionNumber>
  <useIpInProxyHeader>0</useIpInProxyHeader>
  <autoUpdateInterval>86400</autoUpdateInterval>
  <autoUpdateDownloadPkg>1</autoUpdateDownloadPkg>
  <adminEmails>info@tandemcoaching.academy</adminEmails>
  <logging>
    <log>
      <fileName>$SERVER_ROOT/logs/lsws-server.log</fileName>
      <logLevel>DEBUG</logLevel>
      <debugLevel>10</debugLevel>
      <rollingSize>100M</rollingSize>
      <keepDays>7</keepDays>
      <compressArchive>1</compressArchive>
      <enableStderrLog>1</enableStderrLog>
      <enableAioLog>0</enableAioLog>
    </log>
    <accessLog>
      <fileName>$SERVER_ROOT/logs/lsws-access.log</fileName>
      <logHeaders>7</logHeaders>
      <rollingSize>100M</rollingSize>
      <keepDays>30</keepDays>
      <compressArchive>1</compressArchive>
    </accessLog>
  </logging>
  <indexFiles>index.html, index.php</indexFiles>
  <autoIndex>0</autoIndex>
  <htAccess>
    <allowOverride>7</allowOverride>
    <accessFileName>.htaccess</accessFileName>
  </htAccess>
  <expires>
    <enableExpires>1</enableExpires>
    <expiresByType>image/*=A604800, text/css=A604800, application/x-javascript=A604800, application/javascript=A604800,font/*=A604800,application/x-font-ttf=A604800</expiresByType>
  </expires>
  <ipToGeo>
    <geoipDB>
      <geoipDBFile>/home/tca/geoipupdate/GeoLite2-City.mmdb</geoipDBFile>
      <geoipDBName>CITY_DB</geoipDBName>
    </geoipDB>
  </ipToGeo>
  <tuning>
    <reverseDnsLookup>0</reverseDnsLookup>
    <forceSecureCookie>1</forceSecureCookie>
    <maxConnections>10000</maxConnections>
    <maxSSLConnections>10000</maxSSLConnections>
    <connTimeout>300</connTimeout>
    <maxKeepAliveReq>10000</maxKeepAliveReq>
    <keepAliveTimeout>5</keepAliveTimeout>
    <sndBufSize>0</sndBufSize>
    <rcvBufSize>0</rcvBufSize>
    <maxReqURLLen>1024</maxReqURLLen>
    <maxReqHeaderSize>8192</maxReqHeaderSize>
    <maxReqBodySize>500M</maxReqBodySize>
    <maxDynRespHeaderSize>8K</maxDynRespHeaderSize>
    <maxDynRespSize>32M</maxDynRespSize>
    <maxCachedFileSize>4096</maxCachedFileSize>
    <totalInMemCacheSize>256M</totalInMemCacheSize>
    <maxMMapFileSize>256K</maxMMapFileSize>
    <totalMMapCacheSize>256M</totalMMapCacheSize>
    <useSendfile>1</useSendfile>
    <useAIO>1</useAIO>
    <AIOBlockSize>6</AIOBlockSize>
    <fileETag>28</fileETag>
    <enableGzipCompress>1</enableGzipCompress>
    <compressibleTypes>default</compressibleTypes>
    <enableDynGzipCompress>1</enableDynGzipCompress>
    <gzipCompressLevel>6</gzipCompressLevel>
    <enableBrCompress>2</enableBrCompress>
    <gzipAutoUpdateStatic>1</gzipAutoUpdateStatic>
    <gzipStaticCompressLevel>6</gzipStaticCompressLevel>
    <brStaticCompressLevel>5</brStaticCompressLevel>
    <gzipMaxFileSize>10M</gzipMaxFileSize>
    <gzipMinFileSize>512</gzipMinFileSize>
    <sslStrongDhKey>1</sslStrongDhKey>
    <sslCertCompress>1</sslCertCompress>
    <sslHsOffload>1</sslHsOffload>
    <sslSessionCache>0</sslSessionCache>
  </tuning>
  <quic>
    <quicEnable>1</quicEnable>
  </quic>
  <security>
    <wpProtectAction>6</wpProtectAction>
    <wpProtectLimit>3</wpProtectLimit>
    <fileAccessControl>
      <followSymbolLink>1</followSymbolLink>
      <checkSymbolLink>0</checkSymbolLink>
      <requiredPermissionMask>000</requiredPermissionMask>
      <restrictedPermissionMask>000</restrictedPermissionMask>
    </fileAccessControl>
    <perClientConnLimit>
      <staticReqPerSec>0</staticReqPerSec>
      <dynReqPerSec>0</dynReqPerSec>
      <outBandwidth>0</outBandwidth>
      <inBandwidth>0</inBandwidth>
      <softLimit>10000</softLimit>
      <hardLimit>10000</hardLimit>
      <gracePeriod>15</gracePeriod>
      <banPeriod>300</banPeriod>
    </perClientConnLimit>
    <CGIRLimit>
      <maxCGIInstances>200</maxCGIInstances>
      <minUID>11</minUID>
      <minGID>10</minGID>
      <priority>0</priority>
      <CPUSoftLimit>300</CPUSoftLimit>
      <CPUHardLimit>600</CPUHardLimit>
      <memSoftLimit>1450M</memSoftLimit>
      <memHardLimit>1500M</memHardLimit>
      <procSoftLimit>1400</procSoftLimit>
      <procHardLimit>1450</procHardLimit>
    </CGIRLimit>
    <censorshipControl>
      <enableCensorship>1</enableCensorship>
      <logLevel>0</logLevel>
      <defaultAction>deny,log,status:403</defaultAction>
      <scanPOST>1</scanPOST>
      <uploadTmpDir>/tmp</uploadTmpDir>
      <disableSecHtaccess>0</disableSecHtaccess>
      <secAuditLogEngine>1</secAuditLogEngine>
      <secAuditLog>/usr/local/lsws/logs/security-audit.log</secAuditLog>
    </censorshipControl>
    <accessDenyDir>
      <dir>/</dir>
      <dir>/etc/*</dir>
      <dir>/dev/*</dir>
      <dir>$SERVER_ROOT/conf/*</dir>
      <dir>$SERVER_ROOT/admin/conf/*</dir>
    </accessDenyDir>
    <accessControl>
      <allow>ALL</allow>
    </accessControl>
  </security>
  <extProcessorList>
    <extProcessor>
      <type>proxy</type>
      <name>coachgrader-backend</name>
      <address>127.0.0.1:8001</address>
      <maxConns>100</maxConns>
      <initTimeout>5</initTimeout>
      <retryTimeout>5</retryTimeout>
      <respBuffer>0</respBuffer>
    </extProcessor>
    <extProcessor>
      <type>proxy</type>
      <name>coachgrader-frontend</name>
      <address>127.0.0.1:3001</address>
      <maxConns>100</maxConns>
      <initTimeout>5</initTimeout>
      <retryTimeout>5</retryTimeout>
      <respBuffer>0</respBuffer>
    </extProcessor>
  </extProcessorList>
  <cache>
    <storage>
      <cacheStorePath>/usr/local/lsws/tmp/</cacheStorePath>
    </storage>
  </cache>
  <phpConfig>
    <detachedMode>1</detachedMode>
    <controlPanel>auto</controlPanel>
    <maxConns>128</maxConns>
    <env>PHP_LSAPI_CHILDREN=100</env>
    <env>PHP_INI_SCAN_DIR=/usr/local/lsws/lsphp8/lib</env>
    <initTimeout>60</initTimeout>
    <retryTimeout>0</retryTimeout>
    <pcKeepAliveTimeout>1</pcKeepAliveTimeout>
    <respBuffer>0</respBuffer>
    <runOnStartUp>3</runOnStartUp>
    <extMaxIdleTime>60</extMaxIdleTime>
    <memSoftLimit>0</memSoftLimit>
    <memHardLimit>0</memHardLimit>
    <procSoftLimit>0</procSoftLimit>
    <procHardLimit>0</procHardLimit>
  </phpConfig>
  <railsDefaults>
    <maxConns>5</maxConns>
    <env>LSAPI_MAX_IDLE=60</env>
    <initTimeout>180</initTimeout>
    <retryTimeout>0</retryTimeout>
    <pcKeepAliveTimeout>60</pcKeepAliveTimeout>
    <respBuffer>0</respBuffer>
    <backlog>50</backlog>
    <runOnStartUp>1</runOnStartUp>
    <priority>3</priority>
    <memSoftLimit>2047M</memSoftLimit>
    <memHardLimit>2047M</memHardLimit>
    <procSoftLimit>400</procSoftLimit>
    <procHardLimit>500</procHardLimit>
  </railsDefaults>
  <virtualHostList>
    <virtualHost>
      <name>tcawp</name>
      <vhRoot>/home/tca/tcawp/</vhRoot>
      <configFile>/usr/local/lsws/conf/vhosts/tcawp.conf</configFile>
      <allowSymbolLink>1</allowSymbolLink>
      <enableScript>1</enableScript>
      <restrained>0</restrained>
      <setUIDMode>0</setUIDMode>
      <user>tca</user>
      <group>tca</group>
      <chrootMode>0</chrootMode>
    </virtualHost>
    <virtualHost>
      <name>cnpc</name>
      <vhRoot>/home/tca/cnpc/</vhRoot>
      <configFile>/usr/local/lsws/conf/vhosts/cnpc.conf</configFile>
      <allowSymbolLink>1</allowSymbolLink>
      <enableScript>1</enableScript>
      <restrained>0</restrained>
      <setUIDMode>0</setUIDMode>
      <user>tca</user>
      <group>tca</group>
      <chrootMode>0</chrootMode>
    </virtualHost>
    <virtualHost>
      <name>adguard-home</name>
      <vhRoot>/usr/local/lsws/AdGuardHomeProxy</vhRoot>
      <configFile>conf/vhost_AdGuardHomeProxy.conf</configFile>
      <allowSymbolLink>1</allowSymbolLink>
      <enableScript>1</enableScript>
      <restrained>1</restrained>
      <setUIDMode>0</setUIDMode>
      <chrootMode>0</chrootMode>
    </virtualHost>
    <virtualHost>
      <name>coachgrader</name>
      <vhRoot>/opt/coach-grader</vhRoot>
      <configFile>$SERVER_ROOT/conf/vhosts/coachgrader/vhconf.conf</configFile>
      <allowSymbolLink>1</allowSymbolLink>
      <enableScript>1</enableScript>
      <restrained>0</restrained>
      <setUIDMode>0</setUIDMode>
      <user>tca</user>
      <group>tca</group>
      <chrootMode>0</chrootMode>
    </virtualHost>
  </virtualHostList>
  <listenerList>
    <listener>
      <name>tcawp-https</name>
      <address>*:443</address>
      <reusePort>1</reusePort>
      <secure>1</secure>
      <vhostMapList>
        <vhostMap>
          <vhost>tcawp</vhost>
          <domain>tandemcoach.co, tandemcoaching.academy</domain>
        </vhostMap>
        <vhostMap>
          <vhost>cnpc</vhost>
          <domain>cnpc.coach, centerfornonprofitcoaching.org, centerfornonprofitcoaching.com</domain>
        </vhostMap>
        <vhostMap>
          <vhost>adguard-home</vhost>
          <domain>adguard.tandemcoach.co</domain>
        </vhostMap>
        <vhostMap>
          <vhost>coachgrader</vhost>
          <domain>coachgrader.tandemcoach.co</domain>
        </vhostMap>
      </vhostMapList>
      <keyFile>/home/tca/tcawp/certificates/tandem-2024-2025/tandemcoach.co.key</keyFile>
      <certFile>/home/tca/tcawp/certificates/tandem-2024-2025/tandemcoach.co.bundle.cer</certFile>
      <certChain>1</certChain>
      <sslProtocol>24</sslProtocol>
      <enableECDHE>1</enableECDHE>
      <renegProtection>1</renegProtection>
      <sslSessionTickets>1</sslSessionTickets>
      <enableSpdy>15</enableSpdy>
      <enableQuic>1</enableQuic>
    </listener>
  </listenerList>
  <vhTemplateList>
    <vhTemplate>
      <name>centralConfigLog</name>
      <templateFile>$SERVER_ROOT/conf/templates/ccl.xml</templateFile>
      <listeners>tcawp-https</listeners>
    </vhTemplate>
    <vhTemplate>
      <name>PHP_SuEXEC</name>
      <templateFile>$SERVER_ROOT/conf/templates/phpsuexec.xml</templateFile>
      <listeners>tcawp-https</listeners>
    </vhTemplate>
    <vhTemplate>
      <name>EasyRailsWithSuEXEC</name>
      <templateFile>$SERVER_ROOT/conf/templates/rails.xml</templateFile>
      <listeners>tcawp-https</listeners>
    </vhTemplate>
  </vhTemplateList>
</httpServerConfig>
